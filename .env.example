# Discord bot token from Developer Portal
DISCORD_TOKEN=your_token_here

# Required Discord Developer Portal bot settings:
# - Message Content Intent enabled
# - Server Members Intent is not required by this bot

# Optional: Database file path.
# For Docker Compose, keep this at /data/spot_bot.db so the mounted volume persists it.
# DATABASE_PATH=/data/spot_bot.db

# Optional: Leaderboard update interval in seconds (default: 3600 = 1 hour)
# LEADERBOARD_UPDATE_INTERVAL=3600

# Optional: Number of users to show on leaderboard (default: 10)
# LEADERBOARD_SIZE=10
