# Discord bot token from Developer Portal
DISCORD_TOKEN=your_token_here

# Optional: Database file path (default: spot_bot.db)
# DATABASE_PATH=spot_bot.db

# Optional: Leaderboard update interval in seconds (default: 3600 = 1 hour)
# LEADERBOARD_UPDATE_INTERVAL=3600

# Optional: Number of users to show on leaderboard (default: 10)
# LEADERBOARD_SIZE=10
